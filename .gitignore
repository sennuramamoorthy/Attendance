# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Node / Next.js
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.next/
out/
build/
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.ruff_cache/
.pytest_cache/
.mypy_cache/
*.egg-info/

# Env files (secrets — never commit)
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Misc
*.pem
/coverage

# Vercel
.vercel
